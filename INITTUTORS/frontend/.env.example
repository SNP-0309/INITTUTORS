# AMS Frontend — environment config (example).
# Copy to `.env` and adjust. `.env` is git-ignored; `.env.example` is committed.
# Values here are client-safe only — never put secrets in the app bundle.

# Base URL of the AMS backend (no trailing slash, no /api/v1 suffix).
#   Android emulator -> http://10.0.2.2:8000
#   iOS simulator / web / desktop -> http://localhost:8000
API_BASE_URL=http://localhost:8000

# development | staging | production
ENVIRONMENT=development

# Set to true to use local mock data instead of connecting to a running backend.
# Useful for frontend layout, navigation, and UI checking.
USE_MOCK_API=false

