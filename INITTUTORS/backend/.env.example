# =========================================================================
# AMS Backend — environment variables (example).
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# The process fails fast at boot if a required variable is missing.
# =========================================================================

# --- Django core ---
# Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
# Comma-separated. Not required in development (sensible defaults apply).
ALLOWED_HOSTS=localhost,127.0.0.1
# Active settings module: config.settings.development | staging | production
DJANGO_SETTINGS_MODULE=config.settings.development

# --- Database (Supabase PostgreSQL) ---
# Supabase -> Project Settings -> Database -> Connection string (URI).
# For Django migrations prefer the DIRECT/session connection (port 5432).
# For the running app you may use the pooled connection (port 6543, pgBouncer).
# Example (direct):
#   postgresql://postgres:PASSWORD@db.<project-ref>.supabase.co:5432/postgres
# Example (pooled):
#   postgresql://postgres.<project-ref>:PASSWORD@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DB_SSL_REQUIRE=True
DB_CONN_MAX_AGE=600

# --- JWT (djangorestframework-simplejwt) ---
# Signing key for access/refresh tokens. Use a long random value.
JWT_SECRET=change-me-to-a-separate-long-random-string
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=15
JWT_REFRESH_TOKEN_LIFETIME_DAYS=30

# --- CORS ---
# Comma-separated list of allowed frontend origins.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=True

# --- Localization ---
TIME_ZONE=Asia/Kolkata

# --- Notification providers (mocked in dev; real keys in staging/production) ---
# development.md §11: notifications must never fire to real numbers in dev/staging.
SMS_PROVIDER_API_KEY=
WHATSAPP_PROVIDER_API_KEY=
EMAIL_PROVIDER_API_KEY=

# --- Production-only security (ignored in development) ---
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
